\section{Résultats sur le corpus de dialectes}

\begin{frame}{Résultats sur le corpus de dialectes}
\centering
\scriptsize
\begin{tabular}{lc}
\hline
\textbf{Méthode} & \textbf{Accuracy} \\
\hline
Intersection (char 2-gram, top 100) & 49.43\% \\
Intersection (char 3-gram, top 100) & 49.23\% \\
Intersection (char 4-gram, top 100) & 13.43\% \\
Intersection (word 2-gram, top 100) & 40.42\% \\
Intersection (word 3-gram, top 100) & 21.19\% \\
Intersection (word 4-gram, top 100) & 13.43\% \\
kNN (modèle rassemblé) & 57.73\% \\
kNN avec TF-IDF & 66.67\% \\
Régression logistique (BoW) & 84.62\% \\
Naive Bayes (char 3-gram, 2000) & 74.51\% \\
